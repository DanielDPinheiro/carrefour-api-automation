          " pm.collectionVariables.set('runId',r);",
          " pm.collectionVariables.set('adminName','QA Carrefour '+r);",
          " pm.collectionVariables.set('adminEmail','qa.carrefour.'+r+'@teste.com');",
          " pm.collectionVariables.set('adminPassword','Qa@'+r+'A1');",
          " pm.collectionVariables.set('updatedName','QA Carrefour Atualizado '+r);",
          " pm.collectionVariables.set('updatedPassword','Upd@'+r+'B2');",
          "}"
        ]
      }
    }
