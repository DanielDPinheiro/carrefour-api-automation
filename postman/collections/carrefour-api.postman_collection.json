              "raw": "{{baseUrl}}/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "usuarios"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const b=pm.response.json();",
                  "pm.test(\"Contrato da listagem\", function(){ pm.expect(b.usuarios).to.be.an(\"array\"); pm.expect(b.quantidade).to.eql(b.usuarios.length); });",
                  "pm.test(\"Tempo de resposta abaixo de 3000 ms\", function () { pm.expect(pm.response.responseTime).to.be.below(3000); });"
                ]
              }
            }
          ]
        },
        {
